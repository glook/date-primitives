{
    "name": "@glook/date-primitives",
    "version": "0.0.0",
    "description": "Headless date/calendar primitives over react-aria hooks. Gregorian-only by default, locale-agnostic.",
    "keywords": [
        "react",
        "headless",
        "unstyled",
        "datepicker",
        "date-picker",
        "date-range-picker",
        "calendar",
        "date-field",
        "react-aria",
        "accessibility",
        "a11y",
        "aria"
    ],
    "license": "MIT",
    "author": "Andrey Polyakov",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/glook/date-primitives.git"
    },
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc --noEmit",
        "test": "jest",
        "storybook": "storybook dev -p 6008",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@internationalized/date": "^3.12.2",
        "@react-aria/button": "^3.15.1",
        "@react-aria/calendar": "^3.10.1",
        "@react-aria/datepicker": "^3.17.1",
        "@react-aria/i18n": "^3.13.1",
        "@react-aria/utils": "^3.34.1",
        "@react-stately/calendar": "^3.10.1",
        "@react-stately/datepicker": "^3.17.1"
    },
    "devDependencies": {
        "@storybook/react-vite": "^8.6.18",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.5.2",
        "@types/react": "~19.2.17",
        "@vitejs/plugin-react": "^4.7.0",
        "jest": "^30.0.5",
        "jest-environment-jsdom": "^30.1.2",
        "prettier": "^3.2.5",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "storybook": "^8.6.18",
        "ts-jest": "^29.4.1",
        "tsup": "^8.0.2",
        "typescript": "~5.6.2",
        "vite": "^6.4.3"
